# Supabase-Zugangsdaten aus dem Supabase Dashboard kopieren
# Diese Datei nach .env.local kopieren und Werte eintragen
# NIEMALS die .env.local Datei committen!

NEXT_PUBLIC_SUPABASE_URL=https://xxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# Service Role Key — NUR serverseitig verwenden (Server Actions im Admin-Bereich)
# Wird benötigt, um neue User über auth.admin.createUser anzulegen, ohne die
# Admin-Session des aktuell eingeloggten Users zu überschreiben.
# NIEMALS als NEXT_PUBLIC_... exportieren — das wäre ein harter Sicherheits-Breach.
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...
